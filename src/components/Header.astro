---
import { url, NAV } from '../lib/site';
const { active = '' } = Astro.props;
---
<header class="nav">
  <div class="wrap nav-inner">
    <a href={url('/')} class="logo"><span class="mark">G</span>GoyCaz<span class="dim">Labs</span></a>
    <nav class="nav-links" id="navLinks">
      {NAV.map((item) => (
        <a href={url(item.href)} class={active === item.href ? 'active' : ''} data-en={item.en}>{item.es}</a>
      ))}
    </nav>
    <div class="nav-cta">
      <button class="icon-btn theme-btn" id="themeBtn" aria-label="Cambiar tema / Toggle theme">
        <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="4.2"/><path d="M12 2v2.5M12 19.5V22M4.9 4.9l1.8 1.8M17.3 17.3l1.8 1.8M2 12h2.5M19.5 12H22M4.9 19.1l1.8-1.8M17.3 6.7l1.8-1.8"/></svg>
        <svg class="moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 14.5A8 8 0 0 1 9.5 4 8 8 0 1 0 20 14.5z"/></svg>
      </button>
      <div class="lang" role="group" aria-label="Idioma / Language">
        <button id="btnEs" class="active" data-lang="es">ES</button>
        <button id="btnEn" data-lang="en">EN</button>
      </div>
      <a href={url('/contacto')} class="btn btn-ghost" data-en="Talk to us">Conversemos</a>
      <a href={url('/contacto')} class="btn btn-primary" data-en="Book a call">Agenda una llamada</a>
      <button class="menu-btn" id="menuBtn" aria-label="Menú" aria-expanded="false"><span></span><span></span><span></span></button>
    </div>
  </div>
</header>

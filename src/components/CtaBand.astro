---
import { url } from '../lib/site';
---
<section class="block">
  <div class="wrap">
    <div class="cta reveal">
      <div class="cta-single">
        <span class="eyebrow"><span class="bar"></span><span data-en="Next step">Siguiente paso</span><span class="bar"></span></span>
        <h2 style="margin:14px 0 0" data-en="Let's see if this pays off for you.">Veamos si esto te rinde.</h2>
        <p class="lead" data-en="A 20-minute call, no cost and no commitment. We'll tell you straight if AI or software gives you a real return — and how we'd do it.">Una llamada de 20 minutos, sin costo y sin compromiso. Te decimos con franqueza si la IA o el software te dan un retorno real — y cómo lo haríamos.</p>
        <div class="btns">
          <a href={url('/contacto')} class="btn btn-primary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            <span data-en="Start your project">Empecemos tu proyecto</span>
          </a>
          <a href={url('/casos')} class="btn btn-ghost" data-en="See real work">Ver casos reales</a>
        </div>
      </div>
    </div>
  </div>
</section>
